{
	"info": {
		"_postman_id": "skill-svg-server-collection",
		"name": "Skill SVG Server API",
		"description": "Complete API collection for the Skill SVG Server - an Express.js application for managing SVG files with authentication, categories, and usage tracking.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
