						},
						"url": {
							"raw": "{{apiBase}}/users/create-admin",
							"host": ["{{apiBase}}"],
							"path": ["users", "create-admin"]
						},
						"description": "Create a new admin user. Requires ADMIN role authentication."
					},
					"response": []
				}
			],
			"description": "User management endpoints."
		},
		{
			"name": "Categories",
			"item": [
				{
					"name": "List Categories",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiBase}}/categories?page=1&limit=20&search=",
							"host": ["{{apiBase}}"],
							"path": ["categories"],
							"query": [
								{
									"key": "page",
									"value": "1",
									"description": "Page number (default: 1)"
								},
								{
									"key": "limit",
									"value": "20",
									"description": "Items per page, 1-100 (default: 20)"
								},
								{
									"key": "search",
									"value": "",
									"description": "Search term for category name"
								}
							]
						},
						"description": "Get a paginated list of all categories. Public endpoint."
					},
					"response": []
				},
				{
					"name": "Get Category by Slug",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiBase}}/categories/{{categorySlug}}",
							"host": ["{{apiBase}}"],
							"path": ["categories", "{{categorySlug}}"]
						},
						"description": "Get a single category by its slug. Public endpoint."
					},
					"response": []
				},
				{
					"name": "Create Category",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    if (res.data?.id) {",
									"        pm.collectionVariables.set('categoryId', res.data.id);",
									"        pm.collectionVariables.set('categorySlug', res.data.slug);",
									"    }",
									"    pm.test('Category created', function () {",
									"        pm.expect(res.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Icons\",\n    \"description\": \"General purpose icon collection\",\n    \"color\": \"#3B82F6\",\n    \"icon\": \"\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/categories",
							"host": ["{{apiBase}}"],
							"path": ["categories"]
						},
						"description": "Create a new category. Requires ADMIN authentication. Auto-saves categoryId and categorySlug variables."
					},
					"response": []
				},
				{
					"name": "Update Category",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Icons\",\n    \"description\": \"Updated description\",\n    \"color\": \"#EF4444\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/categories/{{categoryId}}",
							"host": ["{{apiBase}}"],
							"path": ["categories", "{{categoryId}}"]
						},
						"description": "Update an existing category by ID. Requires ADMIN authentication. At least one field is required."
					},
					"response": []
				},
				{
					"name": "Delete Category",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{apiBase}}/categories/{{categoryId}}",
							"host": ["{{apiBase}}"],
							"path": ["categories", "{{categoryId}}"]
						},
						"description": "Delete a category by ID. Requires ADMIN authentication."
					},
					"response": []
				}
			],
			"description": "Category management endpoints for organizing SVG files."
		},
		{
			"name": "SVG",
			"item": [
				{
					"name": "List SVG Files",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiBase}}/svg?page=1&limit=20&search=&categoryId=&tag=&visibility=PUBLIC&ownerId=",
							"host": ["{{apiBase}}"],
							"path": ["svg"],
							"query": [
								{
									"key": "page",
									"value": "1",
									"description": "Page number (default: 1)"
								},
								{
									"key": "limit",
									"value": "20",
									"description": "Items per page, 1-100 (default: 20)"
								},
								{
									"key": "search",
									"value": "",
									"description": "Search in title and tags"
								},
								{
									"key": "categoryId",
									"value": "",
									"description": "Filter by category ID (cuid)"
								},
								{
									"key": "tag",
									"value": "",
									"description": "Filter by tag"
								},
								{
									"key": "visibility",
									"value": "PUBLIC",
									"description": "Filter by visibility: PUBLIC, PRIVATE, or UNLISTED"
								},
								{
									"key": "ownerId",
									"value": "",
									"description": "Filter by owner user ID"
								}
							]
						},
						"description": "Get a paginated list of SVG files with optional filters. Public endpoint."
					},
					"response": []
				},
				{
					"name": "Get SVG by Slug",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiBase}}/svg/{{svgSlug}}",
							"host": ["{{apiBase}}"],
							"path": ["svg", "{{svgSlug}}"]
						},
						"description": "Get a single SVG file by its slug. Public endpoint."
					},
					"response": []
				},
				{
					"name": "Serve SVG Icon (Raw)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiBase}}/svg/icons/{{svgSlug}}",
							"host": ["{{apiBase}}"],
							"path": ["svg", "icons", "{{svgSlug}}"]
						},
						"description": "Serve raw SVG content directly with Content-Type: image/svg+xml. Cached for 1 year. Public endpoint."
					},
					"response": []
				},
				{
					"name": "Upload SVG File",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    if (res.data?.slug) {",
									"        pm.collectionVariables.set('svgSlug', res.data.slug);",
									"    }",
									"    pm.test('SVG uploaded', function () {",
									"        pm.expect(res.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}",
								"description": "Optional - sets ownerId if authenticated",
								"disabled": true
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "svg",
									"type": "file",
									"src": "",
									"description": "SVG file to upload (max 5MB, MIME: image/svg+xml)"
								},
								{
									"key": "title",
									"value": "My SVG Icon",
									"type": "text",
									"description": "Optional title (max 120 chars)"
								},
								{
									"key": "visibility",
									"value": "PUBLIC",
									"type": "text",
									"description": "PUBLIC, PRIVATE, or UNLISTED (default: PUBLIC)"
								},
								{
									"key": "categoryId",
									"value": "",
									"type": "text",
									"description": "Optional category ID (cuid)",
									"disabled": true
								},
								{
									"key": "tags",
									"value": "icon,svg,design",
									"type": "text",
									"description": "Comma-separated tags or array"
								}
							]
						},
						"url": {
							"raw": "{{apiBase}}/svg/upload",
							"host": ["{{apiBase}}"],
							"path": ["svg", "upload"]
						},
						"description": "Upload an SVG file. Authentication is optional (guest uploads allowed). Auto-saves svgSlug variable."
					},
					"response": []
				},
