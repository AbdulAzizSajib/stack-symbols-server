		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "sessionToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "testEmail",
			"value": "test@example.com",
			"type": "string"
		},
		{
			"key": "testPassword",
			"value": "password123",
			"type": "string"
		},
		{
			"key": "categoryId",
			"value": "",
			"type": "string"
		},
		{
			"key": "categorySlug",
			"value": "",
			"type": "string"
		},
		{
			"key": "svgSlug",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Server Status",
					"request": {
						"method": "GET",
						"header": [],
