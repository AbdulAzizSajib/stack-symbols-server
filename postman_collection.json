					"name": "Paste SVG Content",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    if (res.data?.slug) {",
									"        pm.collectionVariables.set('svgSlug', res.data.slug);",
									"    }",
									"    pm.test('SVG pasted', function () {",
									"        pm.expect(res.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}",
								"description": "Optional - sets ownerId if authenticated",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"svgContent\": \"<svg xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\" width=\\\"24\\\" height=\\\"24\\\"><circle cx=\\\"12\\\" cy=\\\"12\\\" r=\\\"10\\\" fill=\\\"#3B82F6\\\"/></svg>\",\n    \"title\": \"Blue Circle\",\n    \"visibility\": \"PUBLIC\",\n    \"tags\": [\"circle\", \"blue\", \"shape\"]\n}"
						},
						"url": {
							"raw": "{{apiBase}}/svg/paste",
							"host": ["{{apiBase}}"],
							"path": ["svg", "paste"]
						},
						"description": "Submit SVG content as raw string (paste). Authentication optional. Auto-saves svgSlug variable."
					},
					"response": []
