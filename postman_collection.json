						"description": "Check if the server is running."
					},
					"response": []
				},
				{
					"name": "Database Connection Test",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/db-test",
							"host": ["{{baseUrl}}"],
							"path": ["db-test"]
						},
						"description": "Test database connectivity."
					},
					"response": []
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    pm.collectionVariables.set('testEmail', res.data?.user?.email || pm.collectionVariables.get('testEmail'));",
									"    pm.test('Registration successful', function () {",
									"        pm.expect(res.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/register",
							"host": ["{{apiBase}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new user. Returns user data and requires email verification."
					},
					"response": []
				},
				{
					"name": "Verify Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/verify-email",
							"host": ["{{apiBase}}"],
							"path": ["auth", "verify-email"]
						},
						"description": "Verify user email with OTP code sent via email."
					},
					"response": []
				},
				{
					"name": "Resend OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"type\": \"email-verification\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/resend-otp",
							"host": ["{{apiBase}}"],
							"path": ["auth", "resend-otp"]
						},
						"description": "Resend OTP for email verification or password reset. Type can be 'email-verification' or 'forget-password'."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const res = pm.response.json();",
									"    if (res.data?.accessToken) {",
									"        pm.collectionVariables.set('accessToken', res.data.accessToken);",
									"        pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
									"        pm.collectionVariables.set('sessionToken', res.data.token);",
									"    }",
									"    pm.test('Login successful', function () {",
									"        pm.expect(res.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/login",
							"host": ["{{apiBase}}"],
							"path": ["auth", "login"]
						},
						"description": "Login with email and password. Returns access token, refresh token, and session token. Tokens are also set as cookies."
					},
					"response": []
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{apiBase}}/auth/me",
							"host": ["{{apiBase}}"],
							"path": ["auth", "me"]
						},
						"description": "Get the currently authenticated user's profile. Requires ADMIN or OWNER role."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const res = pm.response.json();",
									"    if (res.data?.accessToken) {",
									"        pm.collectionVariables.set('accessToken', res.data.accessToken);",
									"        pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
									"        pm.collectionVariables.set('sessionToken', res.data.sessionToken);",
									"    }",
									"    pm.test('Token refreshed', function () {",
									"        pm.expect(res.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Cookie",
								"value": "refreshToken={{refreshToken}}; better-auth.session_token={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{apiBase}}/auth/refresh-token",
							"host": ["{{apiBase}}"],
							"path": ["auth", "refresh-token"]
						},
						"description": "Refresh access and session tokens using the refresh token cookie."
					},
					"response": []
				},
				{
					"name": "Change Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"{{testPassword}}\",\n    \"newPassword\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/change-password",
							"host": ["{{apiBase}}"],
							"path": ["auth", "change-password"]
						},
						"description": "Change password for the authenticated user. Password must be 6-20 characters."
					},
					"response": []
				},
				{
					"name": "Forget Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/forget-password",
							"host": ["{{apiBase}}"],
							"path": ["auth", "forget-password"]
						},
						"description": "Request a password reset OTP sent to the user's email."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"otp\": \"123456\",\n    \"newPassword\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "{{apiBase}}/auth/reset-password",
							"host": ["{{apiBase}}"],
							"path": ["auth", "reset-password"]
						},
						"description": "Reset password using email and OTP verification."
					},
					"response": []
				},
				{
					"name": "Google OAuth Login",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{apiBase}}/auth/login/google?redirect=/dashboard",
							"host": ["{{apiBase}}"],
							"path": ["auth", "login", "google"],
							"query": [
								{
									"key": "redirect",
									"value": "/dashboard",
									"description": "Path to redirect after successful login"
								}
							]
						},
						"description": "Initiates Google OAuth login flow. Opens in browser to complete authentication."
					},
					"response": []
				},
				{
					"name": "Google OAuth Success Callback",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{apiBase}}/auth/google/success?redirect=/dashboard",
							"host": ["{{apiBase}}"],
							"path": ["auth", "google", "success"],
							"query": [
								{
									"key": "redirect",
									"value": "/dashboard"
								}
							]
						},
						"description": "Internal callback after successful Google OAuth. Redirects to frontend with tokens."
					},
					"response": []
				},
				{
					"name": "Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.collectionVariables.set('accessToken', '');",
									"    pm.collectionVariables.set('refreshToken', '');",
									"    pm.collectionVariables.set('sessionToken', '');",
									"    pm.test('Logout successful', function () {",
									"        pm.expect(pm.response.json().success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Cookie",
								"value": "better-auth.session_token={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{apiBase}}/auth/logout",
							"host": ["{{apiBase}}"],
							"path": ["auth", "logout"]
						},
						"description": "Logout the authenticated user. Clears all auth cookies and collection variables."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints including registration, login, OAuth, email verification, and password management."
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Create Admin",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
